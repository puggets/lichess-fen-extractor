{
  "manifest_version": 3,
  "name": "Lichess FEN Extractor",
  "version": "1.0",

  "description": "Extract FEN from lichess.",

  "icons": {
    "48": "icons/icon_48.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "lichess_fen_extractor@dino.pugget",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "action": {
    "default_icon": {
      "19": "icons/icon_19.png",
      "38": "icons/icon_38.png"
    },
    "default_title": "Copy FEN",
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["*://*.lichess.org/*"],
      "js": ["script.js"]
    }
  ]
}
